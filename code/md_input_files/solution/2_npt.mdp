title = NPT equilibration
integrator = md
nsteps = 500000
dt = 0.002
nstxout = 500
nstvout = 500
nstenergy = 500
nstlog = 500
continuation = yes
constraint_algorithm = lincs
constraints = h-bonds
rcoulomb = 1.0
rvdw = 1.0
DispCorr = EnerPres
coulombtype = PME
tcoupl = V-rescale
tc_grps = Solute Solvent
tau_t = 0.1 0.1
ref_t = 300 300
pcoupl = C-rescale
pcoupltype = isotropic
tau_p = 2.0
ref_p = 1.0
compressibility = 4.5e-05
refcoord_scaling = com
pbc = xyz
gen_vel = no
